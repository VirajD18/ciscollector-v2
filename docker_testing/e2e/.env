# Number of postgres+ciscollector containers (each gets unique collector-node-N hostname)
COLLECTOR_COUNT=50

# Shared collector token — must match main-server server-node.yaml
COLLECTOR_TOKEN=e2e-test-collector-token-do-not-use-in-prod

# Cron schedule (robfig: minute hour day month weekday)
# */5 * * * * = every 5 minutes (good for local testing)
COLLECTOR_SCHEDULE="*/5 * * * *"

# Collector scan_commands (comma-separated; pii_scanner requires [piiscanner]; log parser requires [collector.logparser])
SCAN_COMMANDS="postgres_cis,hba_scanner,pii_scanner,ssl_audit,inactive_users,unique_ip,unused_lines,password_leak_scanner"

# PII scanner run mode: datascan (regex, no Python) | metascan | deepscan | spacyscan
PII_RUN_OPTION="datascan"

# Optional separate cron for pii_scanner only (robfig). Leave empty to use COLLECTOR_SCHEDULE.
PII_SCHEDULE="0 3 * * 0"

# Optional separate cron for log parser commands (inactive_users, unique_ip, etc.)
LOG_PARSER_SCHEDULE="0 4 * * *"

# Main-server storage: sqlite (default) or postgres
# KSHIELD_DB_DRIVER=sqlite
# KSHIELD_DB_DRIVER=postgres
# MAIN_SERVER_PG_USER=kshield
# MAIN_SERVER_PG_PASSWORD=kshield
# MAIN_SERVER_PG_DB=kshield
# MAIN_SERVER_DATABASE_URL=postgres://kshield:kshield@main-server-db:5432/kshield?sslmode=disable
